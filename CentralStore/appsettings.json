{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "QueueMetadata": {
    "StoreIdHeaderKey": "x-store-id",
    "StoreIdConfigKey": "STORE_ID",
    "LocalStoreQueueName": "local-store-queue-",
    "CentralStoreQueueName": "central-store-queue",
    "Host": "rabbit-mq"
  },
  "Keycloak": {
    "Authority": "http://localhost:6001/realms/rmh-realm",
    "MetadataAddress": "http://localhost:6001/realms/rmh-realm/.well-known/openid-configuration",
    "Audience": "central-api",
    "ValidIssuer": "",
    "AuthorizationUrl": "http://localhost:6001/realms/rmh-realm/protocol/openid-connect/auth",
    "TokenUrl": "http://localhost:6001/realms/rmh-realm/protocol/openid-connect/token"
  }
}
