@page "/products"

@* @attribute [Authorize(Roles = "rmh.products.read")] *@

@using System.Linq;
@using CentralStore.Shared.Dtos;
@using CentralStore.Shared.Dtos.Products
@using CentralStore.StoreManager.Auth2
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid

@inject AuthService AuthService

<h1>Products</h1>

<div class="toolbar">

    @if (AuthService.User.IsInRole("rmh.products.write"))
    {
        <button class="btn btn-primary" @onclick="AddProduct">
            Add
        </button>

        <button class="btn btn-danger"
                @onclick="DeleteSelected"
                disabled="@(!SelectedProducts.Any())">
            Delete
        </button>
    }

    <span class="page-size">
        Show:
        <select @bind="Pagination.ItemsPerPage">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
        </select>
    </span>

</div>

<QuickGrid TGridItem="ProductDtoBase"
           Items="ProductsDtos.AsQueryable()"
           Pagination="Pagination"
           Class="table table-hover">

    <TemplateColumn TGridItem="ProductDtoBase">
        <input type="checkbox"
               checked="@SelectedProducts.Contains(context.Id)"
               @onchange="() => ToggleSelection(context.Id)" />
    </TemplateColumn>

    <PropertyColumn Property="p => p.Name" />
    <PropertyColumn Property="p => p.Description" />
    <PropertyColumn Property="p => p.Price" />
    <PropertyColumn Property="p => p.MinPrice" />
    <PropertyColumn Property="p => p.CreatedAt" />
    <PropertyColumn Property="p => p.UpdatedAt" />

    <TemplateColumn TGridItem="ProductDtoBase" Title="Details">
        <button class="btn btn-link"
                @onclick="() => NavigateToProduct(context.Id)">
            Open
        </button>
    </TemplateColumn>

</QuickGrid>

<Paginator State="Pagination" />