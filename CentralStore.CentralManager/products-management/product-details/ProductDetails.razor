@page "/products/{Id:guid}"

@using CentralStore.Shared.Dtos;
@using Microsoft.AspNetCore.Components.Forms

<h1>Product Details</h1>

@if (isLoading)
{
    <div class="alert alert-info">
        Loading product...
    </div>
}
else if (product == null)
{
    <div class="alert alert-danger">
        Product not found
    </div>
}
else
{
    <EditForm Model="editModel" OnValidSubmit="Save">

        <div class="form-group">
            <label>Id</label>
            <input class="form-control"
                       value="@product.Id"
                       disabled />
        </div>

        <div class="form-group">
            <label>Name</label>
            <InputText class="form-control"
                       @bind-Value="editModel.Name"
                       disabled="@(!isEditable)" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <InputText class="form-control"
                       @bind-Value="editModel.Description"
                       disabled="@(!isEditable)" />
        </div>

        <div class="form-group">
            <label>Price</label>
            <InputNumber class="form-control"
                         @bind-Value="editModel.Price"
                         disabled="@(!isEditable)" />
        </div>

        <div class="form-group">
            <label>Min Price</label>
            <InputNumber class="form-control"
                         @bind-Value="editModel.MinPrice"
                         disabled="@(!isEditable)" />
        </div>

        <div class="form-group">
            <label>Created At</label>
            <InputDate class="form-control"
                       @bind-value="product.CreatedAt"
                       disabled />
        </div>

        <div class="form-group">
            <label>Updated At</label>
            <InputDate class="form-control"
                       @bind-Value="product.UpdatedAt"
                       disabled />
        </div>

        <div class="form-group">
            <label>Store Id</label>
            <input class="form-control"
                   value="@product.StoreId"
                   disabled />
        </div>

        <div class="mt-4">

            <AuthorizeView Context="authContext" Roles="rmh.products.update">
                <button type="button"
                        class="btn btn-secondary"
                        @onclick="EnableEdit"
                        disabled="@isEditable">
                    Edit
                </button>

                <button type="submit"
                        class="btn btn-primary"
                        disabled="@(!isEditable || isSaving)">
                    Save
                </button>

                <button type="button"
                        class="btn btn-warning"
                        @onclick="CancelEdit"
                        disabled="@(!isEditable)">
                    Cancel
                </button>
            </AuthorizeView>

            

            <button type="button"
                    class="btn btn-outline-secondary"
                    @onclick="Back">
                Back
            </button>

        </div>

        @if (isSaving)
        {
            <div class="mt-3 alert alert-info">
                Saving...
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mt-3 alert alert-danger">
                @errorMessage
            </div>
        }

    </EditForm>
}
